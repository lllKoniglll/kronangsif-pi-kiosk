IMG_NAME="kronangsif-pi-kiosk" # Base file name for the generated image artifacts.
PI_GEN_RELEASE="Kronangs IF kiosk" # Human-readable release label written into the image metadata.
ARCH="arm64" # CPU architecture for the Raspberry Pi image build.
RELEASE="trixie" # Debian/Raspberry Pi OS release codename used by pi-gen.
DEPLOY_COMPRESSION="xz" # Compression format used for the exported image artifact.
LOCALE_DEFAULT="sv_SE.UTF-8" # Default system locale baked into the image.
KEYBOARD_KEYMAP="se" # Linux console keyboard map for the image.
KEYBOARD_LAYOUT="Swedish" # Keyboard layout label used by pi-gen keyboard setup.
TIMEZONE_DEFAULT="Europe/Stockholm" # Default system timezone in the image.
TARGET_HOSTNAME="kronangsif-pi" # Hostname assigned to the Raspberry Pi on first boot.
FIRST_USER_NAME="kiosk" # Username for the baked-in first user account.
FIRST_USER_PASS="replace-me" # Password for the baked-in first user account.
DISABLE_FIRST_BOOT_USER_RENAME="1" # Prevent Raspberry Pi OS from forcing a username change on first boot.
PASSWORDLESS_SUDO="0" # Keep sudo password prompts enabled for the first user.
ENABLE_SSH="1" # Enable the SSH service in the generated image.
ENABLE_CLOUD_INIT="0" # Disable cloud-init in the generated image.
WPA_COUNTRY="SE" # Wireless country code passed into pi-gen.
KIOSK_URL="https://kronangsif.github.io" # URL opened automatically by the kiosk browser.
WIFI_SSID="YourNetworkName" # Wi-Fi network name that the kiosk should join on boot.
WIFI_PASSWORD="YourWifiPassword" # Wi-Fi password for the configured network.
WIFI_COUNTRY="SE" # Two-letter regulatory country code for Wi-Fi.
